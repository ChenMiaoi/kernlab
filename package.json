    "url": "git+https://github.com/ChenMiaoi/kernlab.git"
  },
  "keywords": [
    "linux",
    "kernel",
    "qemu",
    "busybox",
    "initramfs",
    "workspace"
  ],
  "author": "ChenMiaoi",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
