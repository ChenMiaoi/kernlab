{
  "name": "create-kernlab",
  "version": "0.1.0",
  "description": "Create a Linux-first QEMU kernel development workspace.",
  "type": "commonjs",
  "bin": {
    "create-kernlab": "bin/create-kernlab.js"
  },
  "files": [
    "bin/",
    "package/submodules.json",
    "Makefile",
    "qemu-linux.mk",
